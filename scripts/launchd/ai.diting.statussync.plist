<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<!-- 装在【MacBook】(推送方)，不是 Mac Studio。把本机各项目救命套件 STATUS/ONBOARDING
     推到 Mac Studio:~/project-status/，供谛听读。
     触发：登录即推(RunAtLoad) + 开着时每 6 小时推一次(StartInterval)。不挑固定时间——
     MacBook 睡觉/合盖时不推，开盖唤醒后自动补推，保证每天用 MacBook 时至少推上一次，
     谛听第二天读即可(STATUS 变化慢，不需当天最新)。
     装：launchctl load -w ~/Library/LaunchAgents/ai.diting.statussync.plist -->
<plist version="1.0">
<dict>
  <key>Label</key>
  <string>ai.diting.statussync</string>
  <key>ProgramArguments</key>
  <array>
    <string>/bin/bash</string>
    <string>/Users/<dev-user>/diting-radar/scripts/sync-status-to-studio.sh</string>
  </array>
  <key>RunAtLoad</key>
  <true/>
  <key>StartInterval</key>
  <integer>21600</integer>
  <key>StandardOutPath</key>
  <string>/Users/<dev-user>/diting-radar/state/statussync.log</string>
  <key>StandardErrorPath</key>
  <string>/Users/<dev-user>/diting-radar/state/statussync.err</string>
</dict>
</plist>
